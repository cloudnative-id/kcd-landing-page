---
const links = {
  Event: [
    { label: "About", href: "/#about" },
    { label: "Speakers", href: "/speakers" },
    { label: "Schedule", href: "/schedule" },
    { label: "Sponsors", href: "/sponsors" },
  ],
  Community: [
    { label: "Call for Papers", href: "/cfp" },
    { label: "Venue", href: "/venue" },
    { label: "FAQ", href: "/faq" },
    { label: "Code of Conduct", href: "https://github.com/cncf/foundation/blob/main/code-of-conduct-languages/id.md" },
  ],
  Connect: [
    { label: "Twitter / X", href: "https://twitter.com/kubernetes_days" },
    { label: "LinkedIn", href: "https://www.linkedin.com/company/kubernetes-community-days-indonesia" },
    { label: "GitHub", href: "https://github.com/cloudnative-id" },
    { label: "YouTube", href: "https://www.youtube.com/@cloudnativeindonesia" },
  ],
};
---

<footer style="background: linear-gradient(160deg, #0D1B2A 0%, #0f2550 60%, #1a3a8f 100%);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <div class="mb-4">
          <img src="/logo-horizontal-white.svg" alt="KCD Indonesia" class="h-7 w-auto" />
        </div>
        <p class="text-white/40 text-sm leading-relaxed mb-4">
          Kubernetes Community Days Indonesia — a CNCF community event.
          October 24, 2026 · Bandung.
        </p>
        <a href="mailto:organizers@cloudnative.id"
          class="text-sm text-[#326CE5] hover:text-white transition-colors">
          organizers@cloudnative.id
        </a>
      </div>

      <!-- Nav columns -->
      {Object.entries(links).map(([category, items]) => (
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-4">{category}</h4>
          <ul class="space-y-2">
            {items.map((link) => (
              <li>
                <a href={link.href}
                  class="text-sm text-white/50 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/10">
      <p class="text-white/30 text-sm">
        &copy; 2026 KCD Indonesia. Part of the CNCF Kubernetes Community Days program.
      </p>
    </div>
  </div>
</footer>
