---
const navLinks = [
  { label: "About", href: "/#about" },
  { label: "Speakers", href: "/speakers" },
  { label: "Schedule", href: "/schedule" },
  { label: "Sponsors", href: "/sponsors" },
  { label: "CFP", href: "/cfp" },
  { label: "Venue", href: "/venue" },
  { label: "FAQ", href: "/faq" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// On non-home pages, the navbar is always over a white background
const isHome = currentPath === '/';
---

<nav
  id="navbar"
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    !isHome && "bg-white border-b border-gray-100 shadow-sm"
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo: blue version for dark/transparent, black for white bg -->
      <a href="/" class="flex items-center">
        <img id="logo-white" src="/logo-horizontal-white.svg" alt="KCD Indonesia"
          class:list={["h-8 w-auto transition-opacity duration-300", !isHome && "hidden"]} />
        <img id="logo-black" src="/logo-horizontal-black.svg" alt="KCD Indonesia"
          class:list={["h-8 w-auto transition-opacity duration-300", isHome && "hidden"]} />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => {
            const isActive = link.href !== '/#about' && currentPath === link.href;
            return (
              <a
                href={link.href}
                class:list={[
                  "nav-link px-3 py-2 text-sm font-medium transition-colors rounded-md",
                  isActive
                    ? "text-[#326CE5]"
                    : isHome
                      ? "text-white/80 hover:text-white"
                      : "text-gray-600 hover:text-[#326CE5]"
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
        <button
          id="register-btn"
          class="ml-4 px-4 py-2 bg-[#326CE5] hover:bg-[#2558d4] text-white text-sm font-semibold rounded-lg transition-colors shadow-sm"
        >
          Register
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class:list={[
          "md:hidden p-2 rounded-md transition-colors",
          isHome ? "text-white/80 hover:text-white hover:bg-white/10" : "text-gray-600 hover:text-gray-900 hover:bg-gray-100"
        ]}
        aria-label="Toggle menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="px-4 py-3 space-y-1">
      {
        navLinks.map((link) => {
          const isActive = link.href !== '/#about' && currentPath === link.href;
          return (
            <a
              href={link.href}
              class={`mobile-nav-link block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                isActive ? "text-[#326CE5] bg-blue-50" : "text-gray-700 hover:text-[#326CE5] hover:bg-blue-50"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
      <button
        id="register-btn-mobile"
        class="register-trigger mobile-nav-link block w-full mt-2 px-4 py-2 bg-[#326CE5] text-white text-sm font-semibold rounded-lg text-center"
      >
        Register
      </button>
    </div>
  </div>
</nav>

<!-- Registration coming soon modal -->
<div
  id="register-modal"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 hidden"
  aria-modal="true"
  role="dialog"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 text-center">
    <!-- Close -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 p-1.5 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Icon -->
    <div class="w-16 h-16 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-5">
      <svg class="w-8 h-8 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>

    <h2 class="text-xl font-black text-gray-900 mb-2">Registration Coming Soon!</h2>
    <p class="text-gray-500 text-sm leading-relaxed mb-6">
      Registration for KCD Indonesia 2026 is not yet open. Follow our social media to get the latest updates on registration, speakers, and event agenda.
    </p>

    <!-- Social links -->
    <div class="flex justify-center gap-3 mb-6">
      <a href="https://t.me/kubernetesindonesia" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-[#326CE5]/30 text-gray-600 hover:text-[#326CE5] text-sm font-medium transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.244-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Telegram
      </a>
      <a href="https://www.instagram.com/cncf.indonesia/" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-[#326CE5]/30 text-gray-600 hover:text-[#326CE5] text-sm font-medium transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        Instagram
      </a>
      <a href="https://www.linkedin.com/company/kubernetes-community-days-indonesia" target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-50 hover:bg-blue-50 border border-gray-200 hover:border-[#326CE5]/30 text-gray-600 hover:text-[#326CE5] text-sm font-medium transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <button
      id="modal-ok"
      class="w-full py-3 bg-[#326CE5] hover:bg-[#2558d4] text-white font-semibold rounded-xl transition-colors"
    >
      Got it!
    </button>
  </div>
</div>

<script>
  const navbar = document.getElementById("navbar");
  const logoBlue = document.getElementById("logo-white") as HTMLImageElement | null;
  const logoBlack = document.getElementById("logo-black") as HTMLImageElement | null;
  const toggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");

  const isHome = window.location.pathname === "/" || window.location.pathname === "";

  function applyScrollState(scrolled: boolean) {
    if (!isHome) return; // non-home pages handled server-side

    if (scrolled) {
      navbar?.classList.add("bg-white", "border-b", "border-gray-100", "shadow-sm");
      navbar?.classList.remove("bg-transparent");
      logoBlue?.classList.add("hidden");
      logoBlack?.classList.remove("hidden");
      navLinks.forEach((l) => {
        l.classList.remove("text-white/80", "hover:text-white");
        l.classList.add("text-gray-600", "hover:text-[#326CE5]");
      });
      const btn = document.getElementById("menu-toggle");
      btn?.classList.remove("text-white/80", "hover:text-white", "hover:bg-white/10");
      btn?.classList.add("text-gray-600", "hover:text-gray-900", "hover:bg-gray-100");
    } else {
      navbar?.classList.remove("bg-white", "border-b", "border-gray-100", "shadow-sm");
      logoBlue?.classList.remove("hidden");
      logoBlack?.classList.add("hidden");
      navLinks.forEach((l) => {
        if (!l.classList.contains("text-[#326CE5]")) {
          l.classList.add("text-white/80", "hover:text-white");
          l.classList.remove("text-gray-600", "hover:text-[#326CE5]");
        }
      });
      const btn = document.getElementById("menu-toggle");
      btn?.classList.add("text-white/80", "hover:text-white", "hover:bg-white/10");
      btn?.classList.remove("text-gray-600", "hover:text-gray-900", "hover:bg-gray-100");
    }
  }

  window.addEventListener("scroll", () => applyScrollState(window.scrollY > 40));
  applyScrollState(window.scrollY > 40);

  toggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });

  // Registration modal
  const modal = document.getElementById("register-modal");
  const backdrop = document.getElementById("modal-backdrop");

  function openModal() {
    modal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    // close mobile menu if open
    mobileMenu?.classList.add("hidden");
    iconOpen?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
  }

  function closeModal() {
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  document.getElementById("register-btn")?.addEventListener("click", openModal);
  document.getElementById("register-btn-mobile")?.addEventListener("click", openModal);
  document.getElementById("modal-close")?.addEventListener("click", closeModal);
  document.getElementById("modal-ok")?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>
