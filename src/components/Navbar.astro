---
const navLinks = [
  { label: "About", href: "/#about" },
  { label: "Speakers", href: "/speakers" },
  { label: "Schedule", href: "/schedule" },
  { label: "Sponsors", href: "/sponsors" },
  { label: "CFP", href: "/cfp" },
  { label: "Venue", href: "/venue" },
  { label: "FAQ", href: "/faq" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// On non-home pages, the navbar is always over a white background
const isHome = currentPath === '/';
---

<nav
  id="navbar"
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    !isHome && "bg-white border-b border-gray-100 shadow-sm"
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo: blue version for dark/transparent, black for white bg -->
      <a href="/" class="flex items-center">
        <img id="logo-white" src="/logo-horizontal-white.svg" alt="KCD Indonesia"
          class:list={["h-8 w-auto transition-opacity duration-300", !isHome && "hidden"]} />
        <img id="logo-black" src="/logo-horizontal-black.svg" alt="KCD Indonesia"
          class:list={["h-8 w-auto transition-opacity duration-300", isHome && "hidden"]} />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => {
            const isActive = link.href !== '/#about' && currentPath === link.href;
            return (
              <a
                href={link.href}
                class:list={[
                  "nav-link px-3 py-2 text-sm font-medium transition-colors rounded-md",
                  isActive
                    ? "text-[#326CE5]"
                    : isHome
                      ? "text-white/80 hover:text-white"
                      : "text-gray-600 hover:text-[#326CE5]"
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
        <a
          href="https://loket.com/event/kcd-indonesia-2026"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-4 px-4 py-2 bg-[#326CE5] hover:bg-[#2558d4] text-white text-sm font-semibold rounded-lg transition-colors shadow-sm"
        >
          Register
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class:list={[
          "md:hidden p-2 rounded-md transition-colors",
          isHome ? "text-white/80 hover:text-white hover:bg-white/10" : "text-gray-600 hover:text-gray-900 hover:bg-gray-100"
        ]}
        aria-label="Toggle menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="px-4 py-3 space-y-1">
      {
        navLinks.map((link) => {
          const isActive = link.href !== '/#about' && currentPath === link.href;
          return (
            <a
              href={link.href}
              class={`mobile-nav-link block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                isActive ? "text-[#326CE5] bg-blue-50" : "text-gray-700 hover:text-[#326CE5] hover:bg-blue-50"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href="https://loket.com/event/kcd-indonesia-2026"
        target="_blank"
        rel="noopener noreferrer"
        class="register-trigger mobile-nav-link block w-full mt-2 px-4 py-2 bg-[#326CE5] text-white text-sm font-semibold rounded-lg text-center"
      >
        Register
      </a>
    </div>
  </div>
</nav>



<script>
  const navbar = document.getElementById("navbar");
  const logoBlue = document.getElementById("logo-white") as HTMLImageElement | null;
  const logoBlack = document.getElementById("logo-black") as HTMLImageElement | null;
  const toggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");

  const isHome = window.location.pathname === "/" || window.location.pathname === "";

  function applyScrollState(scrolled: boolean) {
    if (!isHome) return; // non-home pages handled server-side

    if (scrolled) {
      navbar?.classList.add("bg-white", "border-b", "border-gray-100", "shadow-sm");
      navbar?.classList.remove("bg-transparent");
      logoBlue?.classList.add("hidden");
      logoBlack?.classList.remove("hidden");
      navLinks.forEach((l) => {
        l.classList.remove("text-white/80", "hover:text-white");
        l.classList.add("text-gray-600", "hover:text-[#326CE5]");
      });
      const btn = document.getElementById("menu-toggle");
      btn?.classList.remove("text-white/80", "hover:text-white", "hover:bg-white/10");
      btn?.classList.add("text-gray-600", "hover:text-gray-900", "hover:bg-gray-100");
    } else {
      navbar?.classList.remove("bg-white", "border-b", "border-gray-100", "shadow-sm");
      logoBlue?.classList.remove("hidden");
      logoBlack?.classList.add("hidden");
      navLinks.forEach((l) => {
        if (!l.classList.contains("text-[#326CE5]")) {
          l.classList.add("text-white/80", "hover:text-white");
          l.classList.remove("text-gray-600", "hover:text-[#326CE5]");
        }
      });
      const btn = document.getElementById("menu-toggle");
      btn?.classList.add("text-white/80", "hover:text-white", "hover:bg-white/10");
      btn?.classList.remove("text-gray-600", "hover:text-gray-900", "hover:bg-gray-100");
    }
  }

  window.addEventListener("scroll", () => applyScrollState(window.scrollY > 40));
  applyScrollState(window.scrollY > 40);

  toggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });


</script>
