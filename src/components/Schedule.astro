---
// When the schedule is ready, replace the TBA block below with the Sessionize embed:
// <div data-sessionize-id="YOUR_EVENT_ID" ...></div>
// or paste the Sessionize widget script here.
const sessionizeEmbedReady = false;
---

<section id="schedule" class="py-16 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    {sessionizeEmbedReady ? (
      <!-- Sessionize embed goes here -->
      <div id="sessionize-embed"></div>
    ) : (
      <div class="text-center py-16">
        <!-- Illustration -->
        <div class="w-20 h-20 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>

        <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#326CE5] bg-blue-50 rounded-full mb-4">
          Coming Soon
        </span>
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-3">
          Schedule To Be Announced
        </h2>
        <p class="text-gray-500 max-w-md mx-auto mb-10 leading-relaxed">
          The full agenda for KCD Indonesia 2026 will be published once speakers are confirmed.
          Sessions will cover Kubernetes, cloud native, platform engineering, security, and more.
        </p>

        <!-- Event info pills -->
        <div class="flex flex-wrap justify-center gap-3 mb-10">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200 text-sm text-gray-600">
            <svg class="w-4 h-4 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            October 24, 2026
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200 text-sm text-gray-600">
            <svg class="w-4 h-4 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            09:00 – 18:00 WIB
          </div>
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-50 border border-gray-200 text-sm text-gray-600">
            <svg class="w-4 h-4 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            4 Tracks
          </div>
        </div>

        <!-- CTA -->
        <div class="p-8 rounded-2xl text-white max-w-lg mx-auto"
          style="background: linear-gradient(145deg, #0D1B2A 0%, #0f2550 55%, #326CE5 100%);">
          <p class="text-white/70 text-sm mb-2">Interested in speaking at KCD Indonesia 2026?</p>
          <h3 class="text-xl font-bold text-white mb-4">Submit Your Talk Proposal</h3>
          <p class="text-white/60 text-sm mb-6">
            The CFP is open! Share your knowledge on Kubernetes, cloud native, platform engineering,
            security, observability, or any related topic.
          </p>
          <a href="/cfp"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[#326CE5] font-semibold rounded-xl hover:bg-blue-50 transition-colors shadow-sm">
            Submit a Proposal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    )}

  </div>
</section>
