---
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/hero.webp" alt="" class="w-full h-full object-cover object-center" aria-hidden="true"/>
    <!-- Subtle dark overlay on the left so text stays readable -->
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(3,12,24,0.65) 0%, rgba(3,12,24,0.3) 55%, transparent 100%);"></div>
    <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(3,12,24,0.5) 0%, transparent 40%);"></div>
  </div>

  <!-- Content — left-aligned so it sits over the darker left half -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 items-center min-h-screen py-24">

      <div class="flex flex-col items-center lg:items-start text-center lg:text-left">
        <!-- CNCF badge -->
        <div class="inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full bg-white/8 border border-white/15 text-sm text-white/70 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-[#326CE5] animate-pulse"></span>
          A CNCF Community Event
        </div>

        <!-- Logo -->
        <img src="/logo-vertical-white.svg" alt="KCD Indonesia" class="h-40 w-auto drop-shadow-2xl mb-6"/>

        <!-- Title -->
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-white tracking-tight leading-tight mb-8">
          Kubernetes Community Days<br/>
          <span style="background:linear-gradient(90deg,#93bcff,#ffffff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
            Indonesia 2026
          </span>
        </h1>

        <!-- Date & Location -->
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-5 mb-8">
          <div class="flex items-center gap-2 text-white">
            <svg class="w-5 h-5 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span class="font-semibold">October 24, 2026</span>
          </div>
          <div class="w-px h-4 bg-white/25 hidden sm:block"></div>
          <div class="flex items-center gap-2 text-white">
            <svg class="w-5 h-5 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="font-semibold">Bandung, Indonesia</span>
          </div>
        </div>

        <!-- Countdown -->
        <div class="flex gap-3 sm:gap-4 mb-8" id="countdown">
          {["days","hours","minutes","seconds"].map(unit => (
            <div class="flex flex-col items-center">
              <div class="w-14 h-14 sm:w-18 sm:h-18 bg-white/10 border border-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-1.5">
                <span class="text-xl sm:text-2xl font-black text-white tabular-nums" data-unit={unit}>00</span>
              </div>
              <span class="text-[10px] text-white/45 uppercase tracking-widest">{unit}</span>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-4">
          <button id="hero-register-btn"
            class="px-7 py-3.5 bg-white text-[#326CE5] font-bold rounded-xl text-base transition-all hover:scale-105 hover:shadow-xl hover:shadow-white/10">
            Register Now
          </button>
          <a href="/cfp"
            class="px-7 py-3.5 bg-transparent border-2 border-white/45 text-white hover:bg-white/10 font-bold rounded-xl text-base transition-all hover:scale-105">
            Submit a Talk
          </a>
        </div>
      </div>

      <!-- Right column intentionally empty — hero.png already has the globe here -->

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <a href="#about" class="text-white/25 hover:text-white/50 transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>

</section>

<script>
  function updateCountdown() {
    const diff = new Date("2026-10-24T09:00:00+07:00").getTime() - Date.now();
    if (diff <= 0) return;
    const pad = (n: number) => String(n).padStart(2, "0");
    const el  = (u: string) => document.querySelector(`[data-unit="${u}"]`);
    const d = el("days");    if (d) d.textContent = pad(Math.floor(diff / 86400000));
    const h = el("hours");   if (h) h.textContent = pad(Math.floor((diff % 86400000) / 3600000));
    const m = el("minutes"); if (m) m.textContent = pad(Math.floor((diff % 3600000) / 60000));
    const s = el("seconds"); if (s) s.textContent = pad(Math.floor((diff % 60000) / 1000));
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  document.getElementById("hero-register-btn")?.addEventListener("click", () => {
    document.getElementById("register-modal")?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  });
</script>
