---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background: dark navy → Kubernetes blue gradient -->
  <div class="absolute inset-0" style="background: linear-gradient(160deg, #0D1B2A 0%, #0f2550 50%, #1a3a8f 80%, #326CE5 100%);">
    <!-- Soft radial glow -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 60%, rgba(50,108,229,0.25) 0%, transparent 70%);"></div>
    <!-- Subtle grid -->
    <div class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 60px 60px;">
    </div>
  </div>

  <!-- Floating dots -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[18%] left-[8%]  w-2 h-2 rounded-full bg-white/20 animate-pulse"></div>
    <div class="absolute top-[30%] left-[18%] w-1.5 h-1.5 rounded-full bg-[#326CE5]/60 animate-pulse" style="animation-delay:.4s"></div>
    <div class="absolute top-[65%] left-[6%]  w-3 h-3 rounded-full bg-white/10 animate-pulse" style="animation-delay:.8s"></div>
    <div class="absolute top-[22%] right-[9%] w-2 h-2 rounded-full bg-white/20 animate-pulse" style="animation-delay:.6s"></div>
    <div class="absolute top-[55%] right-[7%] w-1.5 h-1.5 rounded-full bg-[#326CE5]/40 animate-pulse" style="animation-delay:1.2s"></div>
    <div class="absolute bottom-[18%] right-[18%] w-2 h-2 rounded-full bg-white/15 animate-pulse" style="animation-delay:.3s"></div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-20">
    <!-- Logo + Title -->
    <div class="flex flex-col items-center mb-10">
      <img
        src="/logo-vertical-white.svg"
        alt="KCD Indonesia"
        class="h-44 w-auto drop-shadow-2xl mb-6"
      />
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-white tracking-tight leading-tight">
        Kubernetes Community Days<br />
        <span style="background: linear-gradient(90deg, #93bcff, #ffffff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Indonesia 2026
        </span>
      </h1>
    </div>

    <!-- Date & Location -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-10">
      <div class="flex items-center gap-2 text-white">
        <svg class="w-5 h-5 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="font-semibold text-lg">October 24, 2026</span>
      </div>
      <div class="w-px h-5 bg-white/30 hidden sm:block"></div>
      <div class="flex items-center gap-2 text-white">
        <svg class="w-5 h-5 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span class="font-semibold text-lg">Bandung, Indonesia</span>
      </div>
    </div>

    <!-- Countdown -->
    <div class="flex justify-center gap-3 sm:gap-4 mb-10" id="countdown">
      {["days", "hours", "minutes", "seconds"].map((unit) => (
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 sm:w-20 sm:h-20 bg-white/10 border border-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center mb-2">
            <span class="text-2xl sm:text-3xl font-black text-white" data-unit={unit}>00</span>
          </div>
          <span class="text-xs text-white/50 uppercase tracking-widest">{unit}</span>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-4" id="register">
      <button id="hero-register-btn"
        class="px-8 py-4 bg-white text-[#326CE5] font-bold rounded-xl text-lg transition-all hover:scale-105 hover:shadow-xl hover:shadow-white/10">
        Register Now
      </button>
      <a href="/cfp"
        class="px-8 py-4 bg-transparent border-2 border-white/50 text-white hover:bg-white/10 font-bold rounded-xl text-lg transition-all hover:scale-105">
        Submit a Talk
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 flex justify-center animate-bounce">
      <a href="#about" class="text-white/30 hover:text-white/60 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  function updateCountdown() {
    const eventDate = new Date("2026-10-24T09:00:00+07:00");
    const diff = eventDate.getTime() - Date.now();
    if (diff <= 0) return;
    const pad = (n: number) => String(n).padStart(2, "0");
    const el = (u: string) => document.querySelector(`[data-unit="${u}"]`);
    const d = el("days");    if (d) d.textContent = pad(Math.floor(diff / 86400000));
    const h = el("hours");   if (h) h.textContent = pad(Math.floor((diff % 86400000) / 3600000));
    const m = el("minutes"); if (m) m.textContent = pad(Math.floor((diff % 3600000) / 60000));
    const s = el("seconds"); if (s) s.textContent = pad(Math.floor((diff % 60000) / 1000));
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  document.getElementById("hero-register-btn")?.addEventListener("click", () => {
    document.getElementById("register-modal")?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  });
</script>
