---
// Set to true and populate the speakers array once confirmed
const speakersConfirmed = false;
---

<section id="speakers" class="py-16 bg-[#EEF4FF]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    {speakersConfirmed ? (
      <div><!-- Speaker grid goes here --></div>
    ) : (
      <div class="text-center py-16">
        <!-- Illustration -->
        <div class="w-20 h-20 rounded-2xl bg-white border border-blue-100 shadow-sm flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-[#326CE5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>

        <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#326CE5] bg-white border border-blue-100 rounded-full mb-4">
          Coming Soon
        </span>
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-3">
          Speakers To Be Announced
        </h2>
        <p class="text-gray-500 max-w-md mx-auto mb-10 leading-relaxed">
          We're currently reviewing talk proposals. Speakers will be announced once the program committee has completed its selection.
        </p>

        <!-- Placeholder cards -->
        <div class="grid sm:grid-cols-3 gap-4 mb-10 max-w-2xl mx-auto">
          {[1,2,3].map(() => (
            <div class="p-5 rounded-2xl bg-white border border-gray-100 shadow-sm">
              <div class="w-12 h-12 rounded-full bg-gray-100 mx-auto mb-3 animate-pulse"></div>
              <div class="h-3 bg-gray-100 rounded-full w-3/4 mx-auto mb-2 animate-pulse"></div>
              <div class="h-2.5 bg-gray-100 rounded-full w-1/2 mx-auto animate-pulse"></div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="p-8 rounded-2xl text-white max-w-lg mx-auto"
          style="background: linear-gradient(145deg, #0D1B2A 0%, #0f2550 55%, #326CE5 100%);">
          <p class="text-white/70 text-sm mb-2">Want to share your expertise?</p>
          <h3 class="text-xl font-bold text-white mb-4">Speak at KCD Indonesia 2026</h3>
          <p class="text-white/60 text-sm mb-6">
            The CFP is open! We welcome talks on Kubernetes, cloud native, platform engineering,
            security, observability, and more. First-time speakers are encouraged to apply.
          </p>
          <a href="/cfp"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[#326CE5] font-semibold rounded-xl hover:bg-blue-50 transition-colors shadow-sm">
            Submit a Proposal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    )}

  </div>
</section>
