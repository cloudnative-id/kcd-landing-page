---
import fs from 'node:fs';
import path from 'node:path';

const allPhotos = fs
  .readdirSync(path.join(process.cwd(), 'public/community'))
  .filter((f) => /\.(jpe?g|png|webp|gif)$/i.test(f))
  .sort();

const landscapePhotos = allPhotos.filter((f) => f.toUpperCase().startsWith('DSC'));
const portraitPhotos  = allPhotos.filter((f) => f.toUpperCase().startsWith('PIK'));

const stats = [
  { value: "350+", label: "Attendees" },
  { value: "30", label: "Speakers" },
  { value: "27+", label: "Sessions" },
  { value: "4", label: "Tracks" },
];

const expects = [
  {
    icon: "🚀",
    text: "4 different stages with talks from keynote speakers, leading experts, and technical practitioners, while participating in interactive workshops and events.",
  },
  {
    icon: "🤝",
    text: "A lot of different opportunities for networking with other like-minded folks.",
  },
  {
    icon: "🍱",
    text: "Tasty food, snacks, and drinks throughout the entire event!",
  },
  {
    icon: "🌏",
    text: "350+ diverse attendees & speakers including leading experts from open source, DevOps, and cloud native communities.",
  },
  {
    icon: "🏢",
    text: "Community partners & corporate sponsors excited to share their best practices and exchange relevant insights.",
  },
];
---

<section id="about" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#326CE5] bg-blue-50 rounded-full mb-4">
        About the Event
      </span>
      <h2 class="text-4xl sm:text-5xl font-black text-gray-900 mb-6">
        What is <span class="text-[#326CE5]">KCD Indonesia</span>?
      </h2>
      <p class="max-w-3xl mx-auto text-gray-500 text-lg leading-relaxed">
        Kubernetes Community Days Indonesia 2026 is a community-organized tech conference under the
        <span class="text-gray-700 font-medium">Cloud Native Computing Foundation (CNCF)</span> that
        gathers adopters and technologists from open source and cloud native communities to learn,
        collaborate, and network to further the advancement of Kubernetes and the cloud-native
        ecosystem in Indonesia.
      </p>
      <p class="max-w-3xl mx-auto text-gray-400 text-base leading-relaxed mt-4">
        This is a continuation of Kubernetes Community Days 2024, 2022 &amp; 2021 where we had the
        largest community-run online conference in the world at that time, with around 1,300
        participants, 40 speakers, and 5 sponsors.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 rounded-2xl overflow-hidden border border-gray-100 shadow-sm mb-20">
      {stats.map((stat) => (
        <div class="px-8 py-8 text-center bg-white hover:bg-blue-50 transition-colors border-r border-gray-100 last:border-r-0">
          <div class="text-4xl font-black text-[#326CE5] mb-1">{stat.value}</div>
          <div class="text-sm text-gray-400 uppercase tracking-widest">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- What to Expect -->
    <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
      <div>
        <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#326CE5] bg-blue-50 rounded-full mb-4">
          What to Expect
        </span>
        <h3 class="text-3xl font-black text-gray-900 mb-4">
          One Day, Endless<br /><span class="text-[#326CE5]">Possibilities</span>
        </h3>
        <p class="text-gray-500 leading-relaxed">
          KCD Indonesia 2026 is a full-day event packed with technical talks, hands-on workshops,
          and community-driven conversations — all under one roof in Bandung.
        </p>
      </div>

      <div class="space-y-4">
        {expects.map((item) => (
          <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:border-[#326CE5]/20 hover:bg-blue-50/30 transition-all">
            <span class="text-2xl shrink-0 mt-0.5">{item.icon}</span>
            <p class="text-gray-600 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Community in Action -->
    <div class="mb-20">
      <div class="text-center mb-10">
        <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#326CE5] bg-blue-50 rounded-full mb-4">
          Community in Action
        </span>
        <h3 class="text-3xl font-black text-gray-900">
          Memories from <span class="text-[#326CE5]">Past Events</span>
        </h3>
      </div>

      <!-- Landscape photos (DSC) -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3">
        {landscapePhotos.map((file) => (
          <div class="overflow-hidden rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow cursor-zoom-in">
            <img
              src={`/community/${file}`}
              alt="KCD Indonesia community"
              class="lightbox-trigger w-full h-full object-cover aspect-video transition-transform duration-300 hover:scale-105"
              loading="lazy"
              data-src={`/community/${file}`}
            />
          </div>
        ))}
      </div>

      <!-- Portrait photos (PIK) -->
      <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
        {portraitPhotos.map((file) => (
          <div class="overflow-hidden rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow cursor-zoom-in">
            <img
              src={`/community/${file}`}
              alt="KCD Indonesia community"
              class="lightbox-trigger w-full h-full object-cover aspect-[3/4] transition-transform duration-300 hover:scale-105"
              loading="lazy"
              data-src={`/community/${file}`}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Lightbox -->
    <div
      id="lightbox"
      class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4"
      role="dialog"
      aria-modal="true"
    >
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 p-2 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
        aria-label="Close"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Prev -->
      <button
        id="lightbox-prev"
        class="absolute left-4 top-1/2 -translate-y-1/2 p-2 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
        aria-label="Previous"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <img
        id="lightbox-img"
        src=""
        alt="KCD Indonesia community"
        class="max-h-[90vh] max-w-[90vw] rounded-xl shadow-2xl object-contain"
      />

      <!-- Next -->
      <button
        id="lightbox-next"
        class="absolute right-4 top-1/2 -translate-y-1/2 p-2 rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors"
        aria-label="Next"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <!-- Counter -->
      <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/50 text-sm tabular-nums"></div>
    </div>
  </div>
</section>

<script>
  const images = Array.from(document.querySelectorAll<HTMLImageElement>(".lightbox-trigger"));
  // images are already in DOM order: landscape group first, portrait group second
  const lightbox  = document.getElementById("lightbox")!;
  const lbImg     = document.getElementById("lightbox-img") as HTMLImageElement;
  const lbCounter = document.getElementById("lightbox-counter")!;
  let current = 0;

  function show(index: number) {
    current = (index + images.length) % images.length;
    lbImg.src = images[current].dataset.src ?? images[current].src;
    lbCounter.textContent = `${current + 1} / ${images.length}`;
  }

  function open(index: number) {
    show(index);
    lightbox.classList.remove("hidden");
    lightbox.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function close() {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    document.body.style.overflow = "";
  }

  images.forEach((img, i) => img.addEventListener("click", () => open(i)));

  document.getElementById("lightbox-close")?.addEventListener("click", close);
  document.getElementById("lightbox-prev")?.addEventListener("click", () => show(current - 1));
  document.getElementById("lightbox-next")?.addEventListener("click", () => show(current + 1));

  // Close on backdrop click
  lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    if (lightbox.classList.contains("hidden")) return;
    if (e.key === "Escape")      close();
    if (e.key === "ArrowLeft")   show(current - 1);
    if (e.key === "ArrowRight")  show(current + 1);
  });
</script>
