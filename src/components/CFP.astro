---
const topics = [
  "Kubernetes & Container Orchestration",
  "Service Mesh & Networking",
  "Observability & Monitoring",
  "Security & Zero Trust",
  "GitOps & CI/CD",
  "Platform Engineering & IDP",
  "Cloud Native Storage",
  "Serverless & Edge Computing",
  "AI/ML on Kubernetes",
  "Open Source Community",
];

const formats = [
  {
    icon: "🎤",
    title: "Talk (30 min)",
    description: "A full session covering a topic in depth with Q&A.",
  },
  {
    icon: "⚡",
    title: "Lightning Talk (10 min)",
    description: "A rapid-fire talk to share a quick insight or demo.",
  }
];
---

<section id="cfp" class="py-16 bg-white">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Topics & Formats -->
      <div class="space-y-8">
        <!-- Topics -->
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-4">Topics We Love</h3>
          <div class="flex flex-wrap gap-2">
            {topics.map((topic) => (
              <span class="px-3 py-1.5 text-sm rounded-full bg-blue-50 border border-blue-100 text-[#326CE5] hover:bg-[#326CE5] hover:text-white transition-colors cursor-default">
                {topic}
              </span>
            ))}
          </div>
        </div>

        <!-- Formats -->
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-4">Talk Formats</h3>
          <div class="space-y-3">
            {formats.map((f) => (
              <div class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100">
                <span class="text-2xl">{f.icon}</span>
                <div>
                  <div class="font-semibold text-gray-900">{f.title}</div>
                  <div class="text-sm text-gray-500">{f.description}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: CFP card — gradient dark -->
      <div class="p-8 rounded-2xl text-white"
        style="background: linear-gradient(145deg, #0D1B2A 0%, #0f2550 55%, #326CE5 100%);">
        <div class="mb-6">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white/80 text-xs font-semibold mb-4">
            <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
            CFP Now Open
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Submit Your Talk Proposal</h3>
          <p class="text-white/60 text-sm">
            CFP closes on <strong class="text-white">August 15, 2026</strong>.
            Speakers will be notified by September 1, 2026.
          </p>
        </div>

        <div class="space-y-4 mb-8">
          {[
            "Travel support available for selected speakers outside Jakarta",
            "All accepted speakers get complimentary event access",
            "Presentations reviewed by the community program committee",
          ].map((text) => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-white mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-sm text-white/80">{text}</span>
            </div>
          ))}
        </div>

        <a href="/apply-speaker"
          class="block w-full py-4 bg-white text-[#326CE5] font-bold rounded-xl text-center hover:bg-blue-50 transition-colors shadow-sm text-lg">
          Submit a Talk Proposal
        </a>
        <p class="text-center text-xs text-white/40 mt-4">Submissions are reviewed by the program committee</p>
      </div>
    </div>
  </div>
</section>
