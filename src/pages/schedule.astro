---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Schedule from '../components/Schedule.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Schedule — KCD Indonesia 2026"
  description="Full agenda for Kubernetes Community Days Indonesia 2026. Two tracks, keynotes, workshops, and networking — October 24, 2026."
>
  <Navbar />
  <main>
    <PageHero
      badge="Schedule"
      title="Event"
      highlight="Agenda"
      subtitle="October 24, 2026 · All times in WIB (UTC+7)"
    />
    <Schedule />
  </main>
  <Footer />
</Layout>
