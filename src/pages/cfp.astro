---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import CFP from '../components/CFP.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Call for Papers — KCD Indonesia 2026"
  description="Submit a talk proposal for Kubernetes Community Days Indonesia 2026. CFP open until July 31, 2026."
>
  <Navbar />
  <main>
    <PageHero
      badge="Call for Papers"
      title="Share Your"
      highlight="Knowledge"
      subtitle="We welcome talk proposals from everyone in the cloud native community — beginner or veteran."
    />
    <CFP />
  </main>
  <Footer />
</Layout>
